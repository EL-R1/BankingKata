# Environment variables for GitHub Actions
# Copy this file to .env and fill in the values
# NEVER commit the actual values to version control

# Container Registry
REGISTRY=ghcr.io
IMAGE_NAME=bankingkata-api

# GitHub Package Registry (auto-populated)
# GITHUB_TOKEN - Auto provided by GitHub Actions

# Let's Encrypt (for production)
LETSENCRYPT_EMAIL=admin@example.com

# Staging URL
STAGING_URL=https://staging.bankingkata.example.com

# Production URL
PRODUCTION_URL=https://bankingkata.example.com

# Kubernetes (for CD deployments)
KUBECONFIG_DATA=
# Or use individual values:
# KUBE_CONFIG=
# KUBE_CONTEXT=
